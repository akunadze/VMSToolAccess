{
  "name": "toolaccess-user-portal",
  "version": "1.0.0",
  "description": "Self-service kiosk for tool library members",
  "scripts": {
    "start:server": "python electron/server.py",
    "build:flutter": "cd flutter_ui && flutter build web --release --tree-shake-icons",
    "build:bundle": "cd flutter_ui && flutter build bundle",
    "bundle": "powershell -ExecutionPolicy Bypass -File deploy/bundle.ps1"
  }
}
