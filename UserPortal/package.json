{
  "name": "toolaccess-user-portal",
  "version": "1.0.0",
  "description": "Self-service kiosk for tool library members",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron-forge start",
    "build:flutter": "cd flutter_ui && flutter build web --release",
